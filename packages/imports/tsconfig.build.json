{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "rootDir": "./src",
    "paths": {}
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts"]
}
